name: VocaFlow
options:
  bundleIdPrefix: com.vocaflow
  deploymentTarget:
    iOS: "17.0"
  xcodeVersion: "15"
  createIntermediateGroups: true

settings:
  base:
    SWIFT_VERSION: "5.9"
    MARKETING_VERSION: "1.0"
    CURRENT_PROJECT_VERSION: "1"

targets:

  VocaFlow:
    type: application
    platform: iOS
    deploymentTarget: "17.0"
    sources:
      - path: VocaFlow
    settings:
      base:
        PRODUCT_BUNDLE_IDENTIFIER: com.vocaflow.app
        INFOPLIST_FILE: VocaFlow/Info.plist
        DEVELOPMENT_TEAM: ""   # fill in your Apple team ID
    entitlements:
      path: VocaFlow/VocaFlow.entitlements
      properties:
        com.apple.security.application-groups:
          - group.com.vocaflow.app
    dependencies:
      - target: VocaFlowActivity

  VocaFlowActivity:
    type: app-extension
    platform: iOS
    deploymentTarget: "17.0"
    sources:
      # Shared attributes model
      - path: VocaFlow/LiveActivity/RecordingActivityAttributes.swift
      # Widget entry point
      - path: VocaFlowActivity
    settings:
      base:
        PRODUCT_BUNDLE_IDENTIFIER: com.vocaflow.app.activity
        INFOPLIST_FILE: VocaFlowActivity/Info.plist
        DEVELOPMENT_TEAM: ""   # fill in your Apple team ID
